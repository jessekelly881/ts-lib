{
	"compilerOptions": {
		"forceConsistentCasingInFileNames": true,
		"strict": true,
		"noEmit": true,
		"target": "ES2016",
		"module": "NodeNext",
		"noImplicitAny": true,
		"removeComments": true,
		"moduleResolution": "NodeNext",
		"preserveConstEnums": true,
		"esModuleInterop": true,
		"baseUrl": ".",
		"skipLibCheck": true,
		"paths": {
			"@/*": ["./src/*"]
		},
		"plugins": [
			{
				"name": "@effect/language-service"
			}
		]
	},
	"include": ["**/*.ts", "**/*.tsx", "**/*.js", "**/*.jsx"],
	"exclude": ["node_modules", "**/*.spec.ts"]
}
